@model dynamic
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="card shadow-sm p-4">
            <h2 class="text-center mb-4">Create TechMove Account</h2>
            
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="form-group mb-3">
                    <label class="form-label">First Name</label>
                    <input type="text" name="firstName" class="form-control" placeholder="Enter first name" required />
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Last Name</label>
                    <input type="text" name="lastName" class="form-control" placeholder="Enter last name" required />
                </div>
                
                <div class="form-group mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="emailAddress" class="form-control" placeholder="Enter email address" required />
                </div>
                
                <div class="form-group mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="Create a password" required />
                </div>
                
                <button type="submit" class="btn btn-success w-100 mb-3">Register Account</button>
                <div class="text-center">
                    <a asp-action="Login" class="small text-decoration-none">Already have an account? Sign In</a>
                </div>
            </form>
        </div>
    </div>
</div>
