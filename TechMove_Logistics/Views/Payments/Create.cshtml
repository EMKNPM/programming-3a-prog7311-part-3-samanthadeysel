@model TechMove_Logistics.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Create Payment";
}

<h1>Create Payment</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="ContractId" class="control-label"></label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId"></select>
            </div>

            <div class="form-group">
                <label asp-for="AmountUSD" class="control-label">Enter USD</label>
                <input asp-for="AmountUSD" class="form-control" />
                <span asp-validation-for="AmountUSD" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PaymentDate" class="control-label"></label>
                <input asp-for="PaymentDate" type="date" class="form-control" />
                <span asp-validation-for="PaymentDate" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}