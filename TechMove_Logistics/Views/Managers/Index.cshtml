@model IEnumerable<TechMove_Logistics.ViewModels.ManagerViewModel>

@{
    ViewData["Title"] = "Managers";
}

<h1>Managers</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Manager ID</th>
            <th>Service Request</th>
            <th>Status</th>
            <th>Summary</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ManagerId</td>
                <td>@item.ServiceRequestId</td>
                <td>@item.ServiceRequestStatus</td>
                <td>@item.Summary</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ManagerId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.ManagerId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.ManagerId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>