@model TechMove_Logistics.ViewModels.ManagerViewModel

@{
    ViewData["Title"] = "Delete Manager";
}

<h1>Delete Manager</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Manager</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Service Request</dt>
        <dd class="col-sm-10">@Model.ServiceRequestId</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.ServiceRequestStatus</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="ManagerId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>