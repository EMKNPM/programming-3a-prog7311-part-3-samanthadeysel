@model TechMove_Logistics.ViewModels.ServiceRequestViewModel

@{
    ViewData["Title"] = "Service Request Details";
}

<h1>Service Request Details</h1>

<div>
    <h4>Service Request</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Contract</dt>
        <dd class="col-sm-10">@Model.ContractName</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.RequestDateFormatted</dd>

        <dt class="col-sm-2">Cost</dt>
        <dd class="col-sm-10">@Model.FormattedCostUSD</dd>

        <dt class="col-sm-2">Summary</dt>
        <dd class="col-sm-10">@Model.Summary</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ServiceRequestId" class="btn btn-primary">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>